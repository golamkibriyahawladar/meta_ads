# =============================================
# Frontend Variables (ব্রাউজারে যাবে - শুধু App ID)
# =============================================
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# =============================================
# Backend Variables (শুধু Netlify Functions এ থাকবে - সিকিউর)
# =============================================

# Facebook App Secret (Developer Dashboard → Settings → Basic)
APP_SECRET=your_facebook_app_secret_here

# Webhook Verify Token (আপনার নিজের তৈরি যেকোনো সিক্রেট পাসওয়ার্ড)
VERIFY_TOKEN=my_secret_token_123

# Page Access Token (System User থেকে জেনারেট করবেন - Never Expire)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# আপনার Facebook Page এর ID (Page Settings → About → Page ID)
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Graph API Version
GRAPH_API_VERSION=v25.0
