# Meta App ID (For Frontend Facebook Login initialization)
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# Meta App Secret (For Webhook Signature verification)
APP_SECRET=your_facebook_app_secret_here

# Webhook Verify Token (Must match the Verify Token set in the Meta App Developer Dashboard)
VERIFY_TOKEN=my_secret_token_123

# Graph API Version
GRAPH_API_VERSION=v25.0
